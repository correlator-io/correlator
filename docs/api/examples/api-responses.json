  "health_responses": {
    "_description": "Responses from health and readiness probes",

    "health_success": {
      "_endpoint": "GET /health",
      "_status": 200,
      "response": {
        "status": "healthy",
        "serviceName": "correlator",
        "version": "v1.0.0",
        "uptime": "2h15m30s"
      }
    },

    "ping_success": {
      "_endpoint": "GET /ping",
      "_status": 200,
      "_content_type": "text/plain",
      "response": "pong"
    },

    "ready_success": {
      "_endpoint": "GET /ready",
      "_status": 200,
      "_content_type": "text/plain",
      "response": "ready"
    }
  },

  "ingestion_responses": {
    "_description": "Responses from OpenLineage ingestion endpoints",

    "single_lineage_event_success": {
      "_endpoint": "POST /api/v1/lineage",
      "_status": 200,
      "_note": "Returns 200 OK with empty body on success"
    },

    "batch_lineage_events_success": {
      "_endpoint": "POST /api/v1/lineage/batch",
      "_status": 200,
      "_note": "Accepts JSON array of OpenLineage events. Returns 200 OK with empty body on success"
    },

    "lineage_validation_error": {
      "_endpoint": "POST /api/v1/lineage/batch",
      "_status": 400,
      "response": {
        "type": "https://getcorrelator.io/problems/400",
        "title": "Bad Request",
        "status": 400,
        "detail": "Invalid JSON: json: cannot unmarshal object into Go value of type []api.LineageEvent",
        "instance": "/api/v1/lineage/batch",
        "correlation_id": "ee8c0a5fbb40c07d"
      }
    }
  },

