{
  "_description": "Sample API responses for Correlator API endpoints",
  "_usage": "These examples demonstrate successful and error responses for all supported endpoints",
  "_supported_endpoints": [
    "GET /health",
    "GET /ping",
    "GET /ready",
    "POST /api/v1/lineage",
